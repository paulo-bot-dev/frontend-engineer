{
  "$schema": "https://agents.pinata.cloud/schemas/manifest.v1.json",
  "version": 1,

  "agent": {
    "name": "Frontend Engineer",
    "description": "A frontend engineer that builds React + TypeScript apps with Vite. Scaffolds projects, writes components, styles UI, and serves them live with port forwarding.",
    "vibe": "fast, opinionated, ships it",
    "emoji": "🖥️"
  },

  "template": {
    "slug": "frontend-engineer",
    "category": "devops",
    "tags": ["frontend", "react", "typescript", "vite", "developer", "ui"],
    "partnerName": "Pinata"
  },

"skills": [
    {
      "slug": "react-performance"
    }
  ],

  "scripts": {
    "build": "cd workspace/projects/react-app && npm install --include=dev",
    "start": "cd workspace/projects/react-app && npx vite --host 0.0.0.0 --port 5173"
  },

  "routes": [
    {
      "port": 5173,
      "path": "/app",
      "protected": false
    }
  ]
}
